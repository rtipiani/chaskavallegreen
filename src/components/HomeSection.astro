---
const images = [
    "/slide1.avif",
    "/slide2.avif",
    "/slide3.avif",
    "/slide4.avif",
    "/slide5.avif",
];
---
<div id="slider-container" class="relative h-screen overflow-hidden group">
    <!-- Imagen 1 -->
    <img
        id="slide-1"
        src={images[0]}
        alt="Hotel Chaska Valle Green"
        class="absolute inset-0 w-full h-full object-cover opacity-100 transition-opacity duration-1000 z-0 will-change-opacity"
        fetchpriority="high"
    />

    <!-- Imagen 2 (Capa de transición) -->
    <img
        id="slide-2"
        src=""
        alt="Hotel Chaska Valle Green"
        class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000 z-0 will-change-opacity"
    />

    <!-- Superposición oscura -->
    <div class="absolute inset-0 bg-black/45 z-10"></div>

    <!-- Contenido centrado -->
    <div class="relative z-20 flex flex-col items-center justify-center h-full text-white text-center">
        <h1 class="text-5xl font-bold">Chaska Valle Green</h1>
        <p class="text-lg tracking-wide">Vive Momentos de Turismo y Aventura</p>
        <div class="w-20 h-1 bg-yellow-600 mt-4"></div>
    </div>

    <!-- Dots -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-30 flex space-x-3">
        {images.map((_, i) => (
            <button
                class="flex items-center justify-center group py-4"
                aria-label={`Ir al slide ${i}`}
                onclick={`goToSlide(${i})`}
            >
                <div class="slider-dot w-8 h-1 rounded-full bg-white/30 group-hover:bg-white/60 transition-all duration-500"></div>
            </button>
        ))}
    </div>
</div>

<script>
    const img1 = document.getElementById("slide-1") as HTMLImageElement;
    const img2 = document.getElementById("slide-2") as HTMLImageElement;
    const container = document.getElementById("slider-container") as HTMLDivElement;
    const dots = document.querySelectorAll(".slider-dot");
    
    const images = [
        "/slide1.avif",
        "/slide2.avif",
        "/slide3.avif",
        "/slide4.avif",
        "/slide5.avif",
    ];

    let index = 0;
    let interval: number;
    let isTransitioning = false;
    
    let activeImg = img1;
    let inactiveImg = img2;

    function updateSlide(newIndex: number) {
        if (isTransitioning || newIndex === index && activeImg.src.includes(images[newIndex])) return;
        
        isTransitioning = true;
        const nextSrc = images[newIndex];
        
        // 1. Cargar la imagen en la capa inactiva (que está en opacity-0)
        inactiveImg.src = nextSrc;
        
        // 2. ESPERAR a que la imagen esté cargada antes de mostrarla
        inactiveImg.onload = () => {
            // Solo cuando está lista, hacemos el cross-fade
            inactiveImg.classList.replace("opacity-0", "opacity-100");
            activeImg.classList.replace("opacity-100", "opacity-0");
            
            // Actualizar dots
            index = newIndex;
            dots.forEach((dot, i) => {
                dot.classList.toggle("w-12", i === index);
                dot.classList.toggle("bg-white", i === index);
                dot.classList.toggle("w-8", i !== index);
                dot.classList.toggle("bg-white/30", i !== index);
            });

            // Intercambiar roles
            [activeImg, inactiveImg] = [inactiveImg, activeImg];
            
            setTimeout(() => {
                isTransitioning = false;
            }, 1000); // Duración de la transición
        };
    }

    function nextSlide() {
        const nextIndex = (index + 1) % images.length;
        updateSlide(nextIndex);
    }

    (window as any).goToSlide = function (i: number) {
        updateSlide(i);
        resetInterval();
    };

    function startInterval() {
        interval = window.setInterval(nextSlide, 5000); // 5 segundos para que de tiempo a apreciar la imagen
    }

    function resetInterval() {
        clearInterval(interval);
        startInterval();
    }

    // Inicializar primer dot
    dots[0].classList.add("w-12", "bg-white");
    dots[0].classList.remove("w-8", "bg-white/30");
    
    startInterval();

    container.addEventListener("mouseenter", () => clearInterval(interval));
    container.addEventListener("mouseleave", startInterval);
</script>
