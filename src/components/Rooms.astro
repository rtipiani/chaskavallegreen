---
import sql from '../lib/db';

const numeroWhatsapp = "51957708697";

interface Habitacion {
    nombre: string;
    folder: string;
    descripcion: string;
    precio: string;
}

const habitacionesBasicas = (await sql`
    SELECT nombre, folder, descripcion, precio 
    FROM habitaciones 
    ORDER BY orden ASC
`) as Habitacion[];

const habitaciones = habitacionesBasicas.map(h => ({
    ...h,
    imagenes: [`/habitaciones/${h.folder}/1.avif`]
}));
---
<section class="py-16 bg-gray-100">
    <div class="max-w-6xl mx-auto text-center mt-12 px-4">
        <h2 class="text-3xl md:text-4xl font-semibold text-gray-800">
            NUESTRAS <span class="text-yellow-800">HABITACIONES</span>
        </h2>
        <p class="text-gray-600 text-sm md:text-base mt-2">
            En HOTEL CHASKA GREEN, hacemos que tu estadía se convierta en la mejor experiencia.
        </p>
    </div>

    <div class="grid sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto mt-10 px-4">
        {habitaciones.map((habitacion) => {
            const mensaje = encodeURIComponent(`Hola *Hotel Chaska Green*, quiero reservar una *${habitacion.nombre}*.`);
            const linkWhatsapp = `https://wa.me/${numeroWhatsapp}?text=${mensaje}`;

            return (
                <div class="relative overflow-hidden rounded-xl shadow-lg bg-white group flex flex-col h-full">
                    <div class="swiper-container room-slider w-full h-64 overflow-hidden relative select-none">
                        <div class="swiper-wrapper h-full">
                            {habitacion.imagenes.map((img) => (
                                <div class="swiper-slide h-full">
                                    <img 
                                        src={img} 
                                        alt={habitacion.nombre} 
                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 pointer-events-none"
                                        loading="lazy"
                                        width="800" height="600"
                                    />
                                </div>
                            ))}
                        </div>
                        {habitacion.imagenes.length > 1 && (
                            <>
                                <div class="swiper-pagination pointer-events-none"></div>
                                <div class="swiper-button-next !text-white !after:text-xl select-none"></div>
                                <div class="swiper-button-prev !text-white !after:text-xl select-none"></div>
                            </>
                        )}
                    </div>
                    
                    <div class="p-6 text-center flex flex-col flex-grow">
                        <h3 class="text-xl md:text-2xl font-semibold text-gray-800 select-none">{habitacion.nombre}</h3>
                        <p class="text-gray-600 text-sm md:text-base mt-2 flex-grow">{habitacion.descripcion}</p>
                        <p class="text-yellow-800 font-semibold mt-2">{habitacion.precio}</p>
                        <p class="text-gray-600 font-medium text-sm mt-1">Desayuno incluido</p>
                        <a 
                            href={linkWhatsapp} 
                            target="_blank" 
                            class="mt-4 inline-block px-5 py-2 bg-yellow-800 text-white font-semibold rounded-lg hover:bg-yellow-700 transition-colors duration-300"
                        >
                            Reservar ahora <i class="fa-brands fa-whatsapp ml-2"></i>
                        </a>
                    </div>
                </div>
            );
        })}
    </div>
</section>

<style>
    /* Swiper custom styles if needed */
    .room-slider :global(.swiper-pagination-bullet-active) {
        background: #854d0e !important; /* text-yellow-800 */
    }
    .room-slider :global(.swiper-button-next),
    .room-slider :global(.swiper-button-prev) {
        opacity: 0;
        transition: opacity 0.3s ease;
        user-select: none;
        -webkit-tap-highlight-color: transparent;
    }
    .group:hover .room-slider :global(.swiper-button-next),
    .group:hover .room-slider :global(.swiper-button-prev) {
        opacity: 1;
    }
</style>

<script>
    import Swiper from 'swiper';
    import { Navigation, Pagination, Autoplay } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/navigation';
    import 'swiper/css/pagination';

    // Initialize Swiper
    const initSwiper = () => {
        const sliders = document.querySelectorAll('.room-slider');
        
        sliders.forEach((sliderElement) => {
            const slideCount = sliderElement.querySelectorAll('.swiper-slide').length;
            
            new Swiper(sliderElement as HTMLElement, {
                modules: [Navigation, Pagination, Autoplay],
                loop: slideCount > 1, // Solo activar loop si hay más de 1 imagen
                pagination: {
                    el: sliderElement.querySelector('.swiper-pagination') as HTMLElement,
                    clickable: true,
                },
                navigation: {
                    nextEl: sliderElement.querySelector('.swiper-button-next') as HTMLElement,
                    prevEl: sliderElement.querySelector('.swiper-button-prev') as HTMLElement,
                },
                autoplay: slideCount > 1 ? {
                    delay: 5000,
                    disableOnInteraction: false,
                    pauseOnMouseEnter: true
                } : false, // Solo activar autoplay si hay más de 1 imagen
            });
        });
    };

    // Initialize on page load
    initSwiper();

    // Re-initialize if using View Transitions or similar
    document.addEventListener('astro:after-swap', initSwiper);
</script>