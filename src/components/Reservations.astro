---
import sql from '../lib/db';
const habitacionesDb = (await sql`SELECT id, nombre FROM habitaciones ORDER BY orden ASC`) as {id: string, nombre: string}[];
---

<style>
    /* Estilos para manejar el placeholder en inputs de tipo date */
    input[type="date"]:not(:focus):not(:valid) {
        color: transparent;
    }
    
    input[type="date"]:not(:focus):not(:valid)::before {
        content: attr(placeholder);
        color: #9ca3af; /* text-gray-400 */
        position: absolute;
        pointer-events: none;
    }

    /* Asegurar que el selector de fecha se active en todo el campo en móviles */
    input[type="date"]::-webkit-calendar-picker-indicator {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        width: auto;
        height: auto;
        color: transparent;
        background: transparent;
        cursor: pointer;
    }
</style>

<section class="max-w-5xl w-full py-12 p-8 mx-auto mt-5 mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center md:text-left">
        Haz tu reserva rápida y segura.
    </h2>
    <p class="text-gray-600 mb-6 text-center md:text-left">
        Selecciona tu habitación, indica tus fechas, completa tus datos y nuestro equipo de atención al cliente estará siempre disponible para ayudarte. ¡Reserva ahora y vive una experiencia increíble!
    </p>

    <form class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label for="nombres" class="block text-gray-800 font-semibold mb-1">
                Nombres y Apellidos
            </label>
            <input type="text" id="nombres" name="nombres" placeholder="Ingresa tus datos..." class="w-full px-4 py-2 focus:outline focus:outline-yellow-600 rounded-md bg-gray-50">
        </div>

        <div>
            <label for="programaSelect" class="block text-gray-800 font-semibold mb-1">
                Tipo de Habitación
            </label>
            <select id="programaSelect" name="programaSelect" class="w-full px-4 py-2 focus:outline focus:outline-yellow-600 rounded-md bg-gray-50">
                <option value="" disabled selected>
                    Selecciona una habitación
                </option>
            </select>
        </div>

        <div>
            <label for="fechaIngreso" class="block text-gray-800 font-semibold mb-1">
                Fecha de Ingreso
            </label>
            <input 
                type="date" 
                id="fechaIngreso" 
                name="fechaIngreso" 
                required
                placeholder="Selecciona fecha de ingreso"
                class="w-full px-4 py-2 focus:outline focus:outline-yellow-600 rounded-md bg-gray-50 text-gray-700 appearance-none min-h-[44px] relative"
            >
        </div>

        <div>
            <label for="fechaSalida" class="block text-gray-800 font-semibold mb-1">
                Fecha de Salida
            </label>
            <input 
                type="date" 
                id="fechaSalida" 
                name="fechaSalida" 
                required
                placeholder="Selecciona fecha de salida"
                class="w-full px-4 py-2 focus:outline focus:outline-yellow-600 rounded-md bg-gray-50 text-gray-700 appearance-none min-h-[44px] relative"
            >
        </div>

        <div class="md:col-span-2 mt-4">
            <button type="submit" id="consultarBtn" aria-label="Consultar por WhatsApp" class="w-full bg-yellow-800 hover:bg-yellow-700 text-white py-3 rounded-md font-semibold flex items-center justify-center cursor-pointer transition-colors duration-300">
                Consultar Ahora
                <i class="fa-brands fa-whatsapp ml-2"></i>
            </button>
        </div>
    </form>
</section>

<script define:vars={{ initialHabitaciones: habitacionesDb }}>
    document.addEventListener("DOMContentLoaded", function () {
        const habitaciones = initialHabitaciones;

        const habitacionSelect = document.getElementById("programaSelect");
        const nombreInput = document.getElementById("nombres");
        const fechaIngreso = document.getElementById("fechaIngreso");
        const fechaSalida = document.getElementById("fechaSalida");
        const consultarBtn = document.getElementById("consultarBtn");

        if (!habitacionSelect || !nombreInput || !fechaIngreso || !fechaSalida || !consultarBtn) {
            console.error("Error: No se encontraron los elementos del formulario.");
            return;
        }

        habitaciones.forEach(habitacion => {
            const option = document.createElement("option");
            option.value = habitacion.id;
            option.textContent = habitacion.nombre;
            habitacionSelect.appendChild(option);
        });

        function formatoFecha(fechaStr) {
            if (!fechaStr) return "";

            const meses = [
                "enero", "febrero", "marzo", "abril", "mayo", "junio", "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"
            ];

            // Usamos split para evitar problemas de zona horaria con el constructor Date
            const partes = fechaStr.split("-");
            if (partes.length !== 3) return "";
            
            const año = parseInt(partes[0]);
            const mes = meses[parseInt(partes[1]) - 1];
            const dia = parseInt(partes[2]);

            return `${dia} de ${mes} de ${año}`;
        }

        consultarBtn.addEventListener("click", function (event) {
            event.preventDefault();

            const nombre = nombreInput.value.trim();
            const habitacion = habitacionSelect.options[habitacionSelect.selectedIndex]?.text || "" ;
            const ingreso = formatoFecha(fechaIngreso.value);
            const salida = formatoFecha(fechaSalida.value);

            if (!nombre || !habitacionSelect.value || !ingreso || !salida) {
                alert("Por favor, completa todos los campos antes de continuar.");
                return;
            }

            const mensaje = `Hola, *Hotel Chaska Valle Green* me llamo ${nombre} y estoy interesado en una *Habitación: ${habitacion}* del ${ingreso} al ${salida}`;

            const numeroWhatsApp = "51957708697";
            const url = `https://wa.me/${numeroWhatsApp}?text=${encodeURIComponent(mensaje)}`;

            window.open(url, "_blank");
        });
    });
</script>