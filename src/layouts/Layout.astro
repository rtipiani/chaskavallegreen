---
const { 
	title = "Chaska Valle Green | Hotel en Urubamba | Hotel en el valle sagrado | Ubicado a 5 minutos de la plaza principal de Urubamba",
	description = "Disfruta de una estancia cómoda en el hotel Chaska Valle Green. Habitaciones acogedoras, excelente ubicación y servicio de calidad a 5 minutos de la plaza principal de Urubamba. ¡Reserva ahora!",
	keywords = "Chaska Valle Green, hoteles en Cusco, hospedaje en Cusco, alojamiento en Cusco, hotel céntrico en Cusco, habitaciones en Cusco, reservar hotel en Cusco, mejor hotel en Cusco",
	image = "https://hotelchaskavallegreen.com/imagen_seo.avif",
	preloadLCP
} = Astro.props;

const meta = {
	title,
	keywords,
	description,
	url: Astro.url.href,
	image,
};
const { url } = Astro;
const isContactPage = url.pathname.includes("contacts");
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="index, follow" />
		<meta name="author" content="Rubén Tipiani" />
		<meta
			name="copyright"
			content="Copyright (c) 2025, Hotel Chaska Valle Green - RUC: 20613310101"
		/>
		<title>
			{meta.title}
		</title>
		<meta name="description" content={meta.description} />
		<meta name="keywords" content={meta.keywords} />

		<!-- Open Graph / Facebook -->
		<meta property="og:site_name" content="Hotel Chaska Valle Green" />
		<meta property="og:title" content={meta.title} />
		<meta property="og:description" content={meta.description} />
		<meta property="og:image" content={meta.image} />
		<meta property="og:url" content={meta.url} />
		<meta property="og:type" content="website" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/avif" />

		<!-- Twitter Card -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={meta.title} />
		<meta property="twitter:description" content={meta.description} />
		<meta property="twitter:image" content={meta.image} />
		<meta property="twitter:site" content="@hotelchaskavallegreen" />
		<meta
			name="google-site-verification"
			content="ziunduFaSq1K0stHJTa7Ttijv2kYTZztcz0wePK4YX8"
		/>

		<!-- Canonical URL -->
		<link rel="canonical" href={meta.url} />

		<!-- Preload LCP Image -->
		{preloadLCP && <link rel="preload" as="image" href={preloadLCP} fetchpriority="high" />}

		<!-- Structured Data / JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Hotel",
			"name": "Chaska Valle Green",
			"image": meta.image,
			"description": meta.description,
			"url": "https://hotelchaskavallegreen.com/",
			"telephone": "+51957708697",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Urubamba",
				"addressLocality": "Urubamba",
				"addressRegion": "Cusco",
				"addressCountry": "PE"
			}
		})} />

		<!-- Favicon -->
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/apple-touch-icon.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicon-16x16.png"
		/>
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Google reCAPTCHA -->
		{
			isContactPage && (
				<script
					src="https://www.google.com/recaptcha/api.js"
					async
					defer
				/>
			)
		}
	</head>
	<body>
		<main>
			<slot />
		</main>
		<a
			href="https://wa.link/sp0l65"
			target="_blank"
			rel="noopener noreferrer"
			class="fixed bottom-6 right-6 z-30 w-16 h-16 bg-green-500 text-white rounded-full flex items-center justify-center shadow-xl hover:bg-green-600 transition duration-300 transform hover:scale-110"
			aria-label="Ir a Whatsapp"
		>
			<i class="fa-brands fa-whatsapp text-2xl"></i>
		</a>
	</body>
</html>
