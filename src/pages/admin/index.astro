---
import Layout from '../../layouts/Layout.astro';
// import sql from '../../lib/db'; // COMENTADO PARA PRUEBA

let habitaciones = [
    {
        id: "1",
        nombre: "Habitación de Prueba (Si ves esto, el servidor funciona)",
        folder: "simple",
        descripcion: "Si estás viendo esto, significa que el servidor de Vercel está funcionando correctamente y el problema es la conexión a la base de datos.",
        precio: "S/ 000",
        orden: 1,
        mainImage: "https://placehold.co/600x400?text=Servidor+Funcionando"
    }
];
let error = null;

/* 
// Comentamos esto temporalmente para ver si el sitio carga sin DB
try {
    const session = Astro.cookies.get('admin_session');
    if (!session || session.value !== 'authenticated') {
        return Astro.redirect('/admin/login');
    }
    // ... logic ...
} catch (e: any) {
    error = e.message;
}
*/
---

<Layout title="PRUEBA DE VIDA | Chaska Valle Green">
    <div class="min-h-screen bg-white p-20">
        <div class="max-w-4xl mx-auto border-4 border-green-500 p-10 rounded-3xl shadow-2xl">
            <h1 class="text-4xl font-black text-green-600 mb-6">¡EL SERVIDOR ESTÁ VIVO!</h1>
            <p class="text-xl text-gray-700 leading-relaxed mb-8">
                Si puedes leer este mensaje en tu dominio, significa que el servidor de Vercel está configurado correctamente.
            </p>
            
            <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
                <h2 class="font-bold text-gray-900 mb-2">Estado del Diagnóstico:</h2>
                <ul class="list-disc ml-6 space-y-2 text-gray-600">
                    <li>Servidor Vercel: <span class="text-green-600 font-bold">FUNCIONANDO</span></li>
                    <li>Astro v6: <span class="text-green-600 font-bold">FUNCIONANDO</span></li>
                    <li>Conexión a Base de Datos: <span class="text-blue-600 font-bold underline">BAJO INVESTIGACIÓN</span></li>
                </ul>
            </div>

            <div class="mt-10 pt-10 border-t border-gray-100">
                <h3 class="text-lg font-bold mb-4 italic">Vista previa de habitación (Datos locales):</h3>
                {habitaciones.map(h => (
                    <div class="flex gap-6 items-center bg-white p-4 rounded-xl shadow-sm border">
                        <img src={h.mainImage} class="w-32 h-32 rounded-lg object-cover" />
                        <div>
                            <h4 class="font-bold text-xl">{h.nombre}</h4>
                            <p class="text-gray-500">{h.descripcion}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</Layout>
