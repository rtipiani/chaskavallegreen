import Layout from '../../layouts/Layout.astro';
import sql from '../../lib/db';
import fs from 'node:fs';
import path from 'node:path';

const session = Astro.cookies.get('admin_session');
if (!session || session.value !== 'authenticated') {
    return Astro.redirect('/admin/login');
}

const habitacionesBasicas = await sql`SELECT * FROM habitaciones ORDER BY orden ASC`;

// Lógica dinámica para encontrar imágenes
const habitaciones = habitacionesBasicas.map(h => {
    const dirPath = path.join(process.cwd(), 'public', 'habitaciones', h.folder);
    let imagenes = [];
    try {
        if (fs.existsSync(dirPath)) {
            imagenes = fs.readdirSync(dirPath)
                .filter(file => /\.(jpg|jpeg|png|webp|avif)$/i.test(file))
                .sort()
                .map(file => `/habitaciones/${h.folder}/${file}`);
        }
    } catch (e) {
        console.error("Error leyendo carpeta:", dirPath);
    }
    
    return { 
        ...h, 
        mainImage: imagenes.length > 0 ? imagenes[0] : 'https://placehold.co/400x300?text=Subir+Imagen'
    };
});
---

<Layout title="Dashboard | Chaska Valle Green">
    <div class="min-h-screen bg-[#FDFCFB]">
        <!-- Header Profesional -->
        <nav class="bg-white border-b border-gray-100 px-8 py-5 flex justify-between items-center sticky top-0 z-40 shadow-sm">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-yellow-800 rounded-lg flex items-center justify-center text-white shadow-md">
                    <i class="fa-solid fa-hotel text-lg"></i>
                </div>
                <div>
                    <h1 class="text-lg font-bold text-gray-900 leading-none">Chaska Valle Green</h1>
                    <span class="text-xs text-yellow-800 font-semibold tracking-widest uppercase">Panel de Control</span>
                </div>
            </div>
            
            <div class="flex items-center gap-6">
                <a href="/" target="_blank" class="text-sm text-gray-500 hover:text-gray-800 transition-colors flex items-center gap-2">
                    Ver Sitio Web <i class="fa-solid fa-arrow-up-right-from-square text-xs"></i>
                </a>
                <button id="logoutBtn" class="bg-red-50 text-red-600 px-4 py-2 rounded-full text-sm font-bold hover:bg-red-100 transition-all flex items-center gap-2 border border-red-100">
                    <i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión
                </button>
            </div>
        </nav>

        <main class="max-w-6xl mx-auto py-12 px-6">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-4">
                <div>
                    <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">Habitaciones</h2>
                    <p class="text-gray-500 mt-2 text-lg">Gestiona el inventario y los precios de tu hotel en tiempo real.</p>
                </div>
                <div class="bg-white px-4 py-2 rounded-xl border border-gray-100 shadow-sm text-sm text-gray-500">
                    <span class="font-bold text-yellow-800">{habitaciones.length}</span> Habitaciones registradas
                </div>
            </div>

            <div class="grid gap-8">
                {habitaciones.map((habitacion) => (
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:border-yellow-100 transition-all duration-300 overflow-hidden flex flex-col md:flex-row group">
                        <div class="md:w-64 bg-gray-50 flex items-center justify-center border-r border-gray-50 overflow-hidden shrink-0">
                            <img 
                                src={habitacion.mainImage} 
                                alt={habitacion.nombre}
                                class="w-full h-64 md:h-full object-cover group-hover:scale-110 transition-transform duration-700"
                            />
                        </div>
                        <div class="flex-grow p-8 flex flex-col justify-between">
                            <div>
                                <div class="flex flex-col md:flex-row justify-between items-start gap-4">
                                    <h3 class="text-2xl font-bold text-gray-900">{habitacion.nombre}</h3>
                                    <span class="bg-yellow-50 text-yellow-800 px-4 py-1.5 rounded-full text-lg font-black shadow-sm border border-yellow-100 whitespace-nowrap">
                                        {habitacion.precio}
                                    </span>
                                </div>
                                <p class="text-gray-500 mt-3 leading-relaxed text-base max-w-2xl">{habitacion.descripcion}</p>
                            </div>
                            
                            <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between border-t border-gray-50 pt-6 gap-4">
                                <div class="flex gap-4 text-xs text-gray-400 uppercase font-bold tracking-widest">
                                    <span class="flex items-center gap-1.5"><i class="fa-solid fa-check text-green-500"></i> Activo</span>
                                    <span class="flex items-center gap-1.5"><i class="fa-solid fa-image"></i> Multimedia Lista</span>
                                </div>
                                <button 
                                    class="edit-btn inline-flex items-center gap-2 px-6 py-2.5 bg-yellow-800 text-white rounded-xl font-bold hover:bg-yellow-700 hover:translate-y-[-2px] active:translate-y-[0] transition-all shadow-lg shadow-yellow-800/20 w-full sm:w-auto justify-center"
                                    data-room={JSON.stringify(habitacion)}
                                >
                                    <i class="fa-solid fa-pen-to-square"></i> Editar Detalles
                                </button>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </main>
    </div>

    <!-- Modal de Edición Rediseñado -->
    <div id="editModal" class="fixed inset-0 bg-gray-900/40 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl w-full max-w-xl shadow-2xl overflow-hidden transform transition-all border border-gray-100">
            <div class="bg-yellow-800 p-8 text-white">
                <h2 class="text-3xl font-bold">Editar Habitación</h2>
                <p class="text-yellow-100/80 mt-1">Los cambios se verán reflejados inmediatamente en la web.</p>
            </div>
            <form id="editForm" class="p-8 space-y-6">
                <input type="hidden" id="roomId" name="id">
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2">Nombre de Habitación</label>
                        <input type="text" id="roomNombre" name="nombre" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-yellow-600 focus:bg-white transition-all">
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2">Precio Publicado</label>
                        <input type="text" id="roomPrecio" name="precio" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-yellow-600 focus:bg-white transition-all" placeholder="S/ 00 - noche">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2">Descripción Corta</label>
                    <textarea id="roomDesc" name="descripcion" rows="4" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-yellow-600 focus:bg-white transition-all"></textarea>
                </div>

                <div class="flex justify-end gap-4 mt-10 pt-6 border-t border-gray-50">
                    <button type="button" id="closeModal" class="px-6 py-3 text-gray-500 font-bold hover:text-gray-800 transition-colors">Descartar</button>
                    <button type="submit" class="px-8 py-3 bg-yellow-800 text-white font-bold rounded-2xl hover:bg-yellow-700 shadow-xl shadow-yellow-800/30 transition-all flex items-center gap-2">
                        <i class="fa-solid fa-floppy-disk"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</Layout>

<script>
    // Logout
    document.getElementById('logoutBtn')?.addEventListener('click', () => {
        document.cookie = "admin_session=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
        window.location.href = '/admin/login';
    });

    // Modal logic
    const modal = document.getElementById('editModal');
    const editForm = document.getElementById('editForm');
    const closeModal = document.getElementById('closeModal');
    
    const roomIdInput = document.getElementById('roomId');
    const roomNombreInput = document.getElementById('roomNombre');
    const roomPrecioInput = document.getElementById('roomPrecio');
    const roomDescInput = document.getElementById('roomDesc');

    document.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const data = JSON.parse(btn.getAttribute('data-room') || '{}');
            roomIdInput.value = data.id;
            roomNombreInput.value = data.nombre;
            roomPrecioInput.value = data.precio;
            roomDescInput.value = data.descripcion;
            modal.classList.remove('hidden');
        });
    });

    closeModal?.addEventListener('click', () => modal.classList.add('hidden'));

    editForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(editForm);
        const data = Object.fromEntries(formData.entries());

        try {
            const response = await fetch('/api/rooms/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                window.location.reload();
            } else {
                alert('Error al actualizar');
            }
        } catch (error) {
            console.error(error);
            alert('Error inesperado');
        }
    });
</script>
