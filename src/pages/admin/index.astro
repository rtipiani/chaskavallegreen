---
import Layout from '../../layouts/Layout.astro';
import { getDb } from '../../lib/db';

const session = Astro.cookies.get('admin_session');
if (!session || session.value !== 'authenticated') {
    return Astro.redirect('/admin/login');
}

interface Habitacion {
    id: string;
    nombre: string;
    folder: string;
    descripcion: string;
    precio: string;
    orden: number;
}

interface HabitacionConImagen extends Habitacion {
    mainImage: string;
}

let habitaciones: HabitacionConImagen[] = [];
let error: string | null = null;

function getPrimerImagen(folder: string): string {
    const conPrefijo = ['doble', 'matrimonial', 'matrimonial-queen'];
    if (conPrefijo.includes(folder)) {
        return `/habitaciones/${folder}/habitacion-${folder}-1.avif`;
    }
    return `/habitaciones/${folder}/1.avif`;
}

try {
    const sql = getDb();
    const result = await sql`SELECT * FROM habitaciones ORDER BY orden ASC`;
    habitaciones = (result as Habitacion[]).map(h => ({
        ...h,
        mainImage: getPrimerImagen(h.folder)
    }));
} catch (e: any) {
    error = e.message;
    console.error("DB Error:", e);
}
---

<Layout title="Dashboard | Chaska Valle Green">
    {error && (
        <div class="p-8 m-8 bg-red-50 border-2 border-red-300 rounded-xl text-red-700">
            <h2 class="text-xl font-bold mb-2">Error de Base de Datos</h2>
            <code class="block bg-white p-4 rounded border text-sm">{error}</code>
        </div>
    )}

    <div class="min-h-screen bg-[#FDFCFB]">
        <nav class="bg-white border-b border-gray-100 px-4 md:px-8 py-4 md:py-5 flex justify-between items-center sticky top-0 z-40 shadow-sm">
            <div class="flex items-center gap-2 md:gap-3">
                <div class="w-8 h-8 md:w-10 md:h-10 bg-yellow-800 rounded-lg flex items-center justify-center text-white shadow-md shrink-0">
                    <i class="fa-solid fa-hotel text-sm md:text-lg"></i>
                </div>
                <div class="min-w-0">
                    <h1 class="text-sm md:text-lg font-bold text-gray-900 leading-none truncate">Chaska Valle Green</h1>
                    <span class="text-[10px] md:text-xs text-yellow-800 font-semibold tracking-widest uppercase block mt-0.5">Panel de Control</span>
                </div>
            </div>

            <div class="flex items-center gap-3 md:gap-6">
                <a href="/" target="_blank" class="text-xs md:text-sm text-gray-500 hover:text-gray-800 transition-colors flex items-center gap-1.5 font-medium">
                    <span class="hidden sm:inline">Ver Sitio Web</span>
                    <i class="fa-solid fa-arrow-up-right-from-square text-[10px] md:text-xs"></i>
                </a>
                
                <a href="/api/auth/logout" class="bg-red-50 text-red-600 px-3 md:px-4 py-1.5 md:py-2 rounded-full text-[10px] md:text-sm font-bold hover:bg-red-100 transition-all flex items-center gap-1.5 border border-red-100">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <span>Cerrar <span class="hidden xs:inline">Sesión</span></span>
                </a>
            </div>
        </nav>

        <main class="max-w-6xl mx-auto py-12 px-6">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-10 gap-4">
                <div>
                    <h2 class="text-4xl font-extrabold text-gray-900 tracking-tight">Habitaciones</h2>
                    <p class="text-gray-500 mt-2 text-lg">Gestiona el inventario y los precios de tu hotel en tiempo real.</p>
                </div>
                <div class="bg-white px-4 py-2 rounded-xl border border-gray-100 shadow-sm text-sm text-gray-500">
                    <span class="font-bold text-yellow-800">{habitaciones.length}</span> Habitaciones registradas
                </div>
            </div>

            <div class="grid gap-8">
                {habitaciones.map((habitacion) => (
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:border-yellow-100 transition-all duration-300 overflow-hidden flex flex-col md:flex-row group">
                        <div class="md:w-64 bg-gray-50 flex items-center justify-center border-r border-gray-50 overflow-hidden shrink-0">
                            <img
                                src={habitacion.mainImage}
                                alt={habitacion.nombre}
                                class="w-full h-64 md:h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                onerror="this.src='https://placehold.co/400x300?text=Sin+Imagen'"
                            />
                        </div>
                        <div class="flex-grow p-8 flex flex-col justify-between">
                            <div>
                                <div class="flex flex-col md:flex-row justify-between items-start gap-4">
                                    <h3 class="text-2xl font-bold text-gray-900">{habitacion.nombre}</h3>
                                    <span class="bg-yellow-50 text-yellow-800 px-4 py-1.5 rounded-full text-lg font-black shadow-sm border border-yellow-100 whitespace-nowrap">
                                        {habitacion.precio}
                                    </span>
                                </div>
                                <p class="text-gray-500 mt-3 leading-relaxed text-base max-w-2xl">{habitacion.descripcion}</p>
                            </div>
                            <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between border-t border-gray-50 pt-6 gap-4">
                                <div class="flex gap-4 text-xs text-gray-400 uppercase font-bold tracking-widest">
                                    <span class="flex items-center gap-1.5"><i class="fa-solid fa-check text-green-500"></i> Activo</span>
                                </div>
                                <button
                                    class="edit-btn inline-flex items-center gap-2 px-6 py-2.5 bg-yellow-800 text-white rounded-xl font-bold hover:bg-yellow-700 transition-all shadow-lg w-full sm:w-auto justify-center"
                                    data-room={JSON.stringify(habitacion)}
                                >
                                    <i class="fa-solid fa-pen-to-square"></i> Editar Detalles
                                </button>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </main>
    </div>

    <!-- Modal -->
    <div id="editModal" class="fixed inset-0 bg-gray-900/40 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl w-full max-w-xl shadow-2xl overflow-hidden border border-gray-100">
            <div class="bg-yellow-800 p-8 text-white">
                <h2 class="text-3xl font-bold">Editar Habitación</h2>
                <p class="text-yellow-100/80 mt-1">Los cambios se verán reflejados inmediatamente en la web.</p>
            </div>
            <form id="editForm" class="p-8 space-y-6">
                <input type="hidden" id="roomId" name="id">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2">Nombre</label>
                        <input type="text" id="roomNombre" name="nombre" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-yellow-600 focus:bg-white transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2">Precio</label>
                        <input type="text" id="roomPrecio" name="precio" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-yellow-600 focus:bg-white transition-all" placeholder="S/ 00 - noche">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-bold text-gray-700 uppercase tracking-wider mb-2">Descripción</label>
                    <textarea id="roomDesc" name="descripcion" rows="4" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl outline-none focus:ring-2 focus:ring-yellow-600 focus:bg-white transition-all"></textarea>
                </div>
                <div class="flex justify-end gap-4 pt-6 border-t border-gray-50">
                    <button type="button" id="closeModal" class="px-6 py-3 text-gray-500 font-bold hover:text-gray-800 transition-colors">Descartar</button>
                    <button type="submit" class="px-8 py-3 bg-yellow-800 text-white font-bold rounded-2xl hover:bg-yellow-700 shadow-xl transition-all flex items-center gap-2">
                        <i class="fa-solid fa-floppy-disk"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-6 right-6 z-[9999] flex items-center gap-3 px-6 py-4 rounded-2xl shadow-2xl text-white font-bold text-sm translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
        <i id="toastIcon" class="fa-solid fa-circle-check text-lg"></i>
        <span id="toastMsg">Cambios guardados correctamente</span>
    </div>
</Layout>

<script>
    const modal = document.getElementById('editModal') as HTMLDivElement;
    const editForm = document.getElementById('editForm') as HTMLFormElement;
    const closeModal = document.getElementById('closeModal');
    const roomIdInput = document.getElementById('roomId') as HTMLInputElement;
    const roomNombreInput = document.getElementById('roomNombre') as HTMLInputElement;
    const roomPrecioInput = document.getElementById('roomPrecio') as HTMLInputElement;
    const roomDescInput = document.getElementById('roomDesc') as HTMLTextAreaElement;

    document.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const data = JSON.parse(btn.getAttribute('data-room') || '{}');
            roomIdInput.value = data.id;
            roomNombreInput.value = data.nombre;
            roomPrecioInput.value = data.precio;
            roomDescInput.value = data.descripcion;
            modal.classList.remove('hidden');
        });
    });

    closeModal?.addEventListener('click', () => modal.classList.add('hidden'));

    // Toast helper
    function showToast(message: string, isError = false) {
        const toast = document.getElementById('toast') as HTMLDivElement;
        const toastMsg = document.getElementById('toastMsg') as HTMLSpanElement;
        const toastIcon = document.getElementById('toastIcon') as HTMLElement;

        toastMsg.textContent = message;
        toast.className = `fixed bottom-6 right-6 z-[9999] flex items-center gap-3 px-6 py-4 rounded-2xl shadow-2xl text-white font-bold text-sm transition-all duration-500 ${
            isError ? 'bg-red-500' : 'bg-green-600'
        }`;
        toastIcon.className = `fa-solid ${ isError ? 'fa-circle-xmark' : 'fa-circle-check' } text-lg`;

        // Animate in
        requestAnimationFrame(() => {
            toast.style.transform = 'translateY(0)';
            toast.style.opacity = '1';
        });

        // Animate out after 3s
        setTimeout(() => {
            toast.style.transform = 'translateY(5rem)';
            toast.style.opacity = '0';
        }, 3000);
    }

    editForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = editForm.querySelector('[type="submit"]') as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Guardando...';

        const data = Object.fromEntries(new FormData(editForm).entries());
        try {
            const response = await fetch('/api/rooms/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            if (response.ok) {
                modal.classList.add('hidden');
                showToast('¡Cambios guardados correctamente!');
                setTimeout(() => window.location.reload(), 1500);
            } else {
                showToast('Error al actualizar. Inténtalo de nuevo.', true);
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Guardar Cambios';
            }
        } catch (err) {
            showToast('Error de conexión inesperado.', true);
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Guardar Cambios';
        }
    });
</script>
